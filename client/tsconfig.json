{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* 🔥 IMPORTANT */
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* Good practice */
    "strict": true,
    "noEmit": true,

    /* Vite requirement */
    "types": ["vite/client"]
  },
  "include": ["src"]
}